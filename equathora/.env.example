# =============================================================================
# Equathora Frontend Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit your .env file to version control!
# =============================================================================

# Supabase Configuration
# Get these from: https://app.supabase.com → Project Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Backend API
# Required in production so API requests do not hit the frontend SPA rewrite.
# In local dev, you can leave this commented and rely on vite.config.js proxy.
# VITE_API_URL=http://localhost:5104
# Optional aliases (same purpose):
# VITE_BACKEND_URL=http://localhost:5104
# VITE_API_BASE_URL=http://localhost:5104

# PostHog Product Analytics (optional but recommended)
# Free tier is available at https://posthog.com/pricing.
# Create a project, copy the project API key, then set host to US or EU.
# VITE_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# VITE_POSTHOG_HOST=https://us.i.posthog.com

# Optional Vercel Speed Insights toggle.
# Keep disabled unless you explicitly want Speed Insights and your runtime supports full performance mark APIs.
# VITE_ENABLE_SPEED_INSIGHTS=true
# VITE_POSTHOG_HOST=https://eu.i.posthog.com
